from dask import delayed, compute
import ray
import numpy as np
import matplotlib.pyplot as plt

# Initialize Ray
ray.init(ignore_reinit_error=True)

# Vector Definitions
class Vector:
    def __init__(self, name, initial_position, dynamics):
        self.name = name
        self.position = np.array(initial_position)
        self.dynamics = dynamics

    def update_position(self, time):
        """
        Update the position of the vector based on its dynamics.
        """
        self.position = self.dynamics(self.position, time)
        return self.position

# Define the dynamics of the vectors
def gentuo_dynamics(position, time):
    """Gentuo vector dynamics: spiraling motion."""
    x, y, z = position
    return [
        np.cos(time) + x * 0.1,
        np.sin(time) + y * 0.1,
        z + 0.1 * np.sin(time)
    ]

def valhalla_dynamics(position, time):
    """Valhalla vector dynamics: stability and lattice-like motion."""
    x, y, z = position
    return [
        x + 0.1 * np.cos(time),
        y - 0.1 * np.sin(time),
        z
    ]

def warden_dynamics(gentuo_position, valhalla_position, time):
    """Warden vector dynamics: maintain rotation of Gentuo around Valhalla."""
    x_g, y_g, z_g = gentuo_position
    x_v, y_v, z_v = valhalla_position

    # Calculate rotation vector
    dx = x_g - x_v
    dy = y_g - y_v
    dz = z_g - z_v

    # Rotate around Valhalla vector's position
    rotation_speed = 0.05
    rotated_x = x_v + dx * np.cos(rotation_speed * time) - dy * np.sin(rotation_speed * time)
    rotated_y = y_v + dx * np.sin(rotation_speed * time) + dy * np.cos(rotation_speed * time)
    rotated_z = z_g  # Maintain the z-plane for simplicity

    return [rotated_x, rotated_y, rotated_z]

# Initialize Vectors
gentuo_vector = Vector("Gentuo", [1.0, 0.0, 0.0], gentuo_dynamics)
valhalla_vector = Vector("Valhalla", [0.0, 1.0, 0.0], valhalla_dynamics)
warden_vector = Vector("Warden", [0.0, 0.0, 0.0], None)  # Warden dynamics are custom

# Dask and Ray Coordination
@ray.remote
def compute_vector_position(vector, time):
    """Update vector position with Ray."""
    return vector.update_position(time)

def simulate_vectors(gentuo, valhalla, warden, timesteps):
    """
    Simulate the dynamics of the vectors over the given timesteps.
    """
    positions = {"Gentuo": [], "Valhalla": [], "Warden": []}

    for t in range(timesteps):
        # Update Gentuo and Valhalla positions
        gentuo_pos = compute_vector_position.remote(gentuo, t)
        valhalla_pos = compute_vector_position.remote(valhalla, t)
        gentuo_result, valhalla_result = ray.get([gentuo_pos, valhalla_pos])

        # Update Warden to maintain rotation
        warden_position = warden_dynamics(gentuo_result, valhalla_result, t)
        warden.position = warden_position

        # Store results
        positions["Gentuo"].append(gentuo_result)
        positions["Valhalla"].append(valhalla_result)
        positions["Warden"].append(warden_position)

    return positions

# Run Simulation
timesteps = 100
positions = simulate_vectors(gentuo_vector, valhalla_vector, warden_vector, timesteps)

# Visualization
def visualize_vectors(positions):
    """
    Visualize the vector dynamics in 3D space.
    """
    fig = plt.figure(figsize=(10, 8))
    ax = fig.add_subplot(111, projection='3d')

    for vector_name, pos in positions.items():
        pos = np.array(pos)
        ax.plot(pos[:, 0], pos[:, 1], pos[:, 2], label=f"{vector_name} Path")

    ax.set_title("Gentuo, Valhalla, and Warden Vector Dynamics")
    ax.set_xlabel("X Axis")
    ax.set_ylabel("Y Axis")
    ax.set_zlabel("Z Axis")
    ax.legend()
    plt.show()

# Visualize the results
visualize_vectors(positions)

# Cleanup Ray resources
ray.shutdown()