import numpy as np
import dask.array as da
import matplotlib.pyplot as plt
import logging


class ZenGarden:
    def __init__(self, frequency=1.0, use_dask=True, chunk_size=1000):
        """
        Initialize ZenGarden with optional Dask support for distributed processing.
        """
        self.frequency = frequency
        self.use_dask = use_dask
        self.chunk_size = chunk_size  # Dask chunk size for distributed arrays
        logging.info(f"ZenGarden initialized. Use Dask: {self.use_dask}")

    def generate_vector_field(self, size):
        """
        Generate a vector field for processing. Uses Dask if enabled and size exceeds chunk_size.
        """
        if self.use_dask and size > self.chunk_size:
            vector_field = da.random.random((size, 2), chunks=(self.chunk_size, 2))
            logging.info(f"Generated distributed vector field of size {size} using Dask.")
        else:
            vector_field = np.random.rand(size, 2)
            logging.info(f"Generated sequential vector field of size {size} using NumPy.")
        return vector_field

    def apply_coherence_transform(self, vector_field):
        """
        Apply coherence transformations to a vector field. Uses Dask or NumPy based on input type.
        """
        if isinstance(vector_field, da.Array):
            # Dask coherence transform
            normalized_field = vector_field.map_blocks(
                lambda block: block / np.linalg.norm(block, axis=1, keepdims=True)
            )
            logging.info("Applied coherence transformations to distributed vector field.")
        else:
            # NumPy coherence transform
            normalized_field = vector_field / np.linalg.norm(vector_field, axis=1, keepdims=True)
            logging.info("Applied coherence transformations to sequential vector field.")
        return normalized_field

    def visualize_vector_field(self, vector_field, title="Vector Field"):
        """
        Visualize the vector field using a quiver plot. Computes Dask arrays if needed.
        """
        if isinstance(vector_field, da.Array):
            vector_field = vector_field.compute()  # Gather data into memory for visualization
        x, y = vector_field[:, 0], vector_field[:, 1]
        plt.quiver(range(len(x)), range(len(y)), x, y, angles='xy', scale_units='xy', scale=1, color="blue")
        plt.title(title)
        plt.xlabel("X-axis")
        plt.ylabel("Y-axis")
        plt.grid(True)
        plt.show()

    def process_gate(self, size):
        """
        Simulate processing at a gate with vector transformations.
        """
        logging.info(f"Processing gate with ZenGarden, generating vector field of size {size}.")
        vector_field = self.generate_vector_field(size)
        transformed_field = self.apply_coherence_transform(vector_field)
        self.visualize_vector_field(transformed_field, title="Processed Vector Field at Top Gate")
        return transformed_field