import numpy as np
import gym
from stable_baselines3 import PPO
from typing import List

class NetworkAnalysisEnv(gym.Env):
    def __init__(self, traffic_data: List[dict]):
        super(NetworkAnalysisEnv, self).__init__()

        # Define the state and action space
        self.observation_space = gym.spaces.Box(low=0, high=1, shape=(len(traffic_data[0]),), dtype=np.float32)
        self.action_space = gym.spaces.Discrete(3)  # Actions: 0 = Ignore, 1 = Analyze, 2 = Flag

        self.traffic_data = traffic_data
        self.current_index = 0
        self.total_reward = 0

    def step(self, action):
        # Get current traffic entry
        entry = self.traffic_data[self.current_index]
        malicious = entry['malicious']

        # Define reward logic
        if action == 1 and malicious:
            reward = 1  # Correctly analyzed malicious traffic
        elif action == 2 and malicious:
            reward = 2  # Correctly flagged malicious traffic
        elif action in [1, 2] and not malicious:
            reward = -1  # False positive
        else:
            reward = 0  # Ignored traffic

        self.total_reward += reward

        # Move to the next entry
        self.current_index += 1
        done = self.current_index >= len(self.traffic_data)

        # Observation for the next state
        if not done:
            observation = np.array(list(self.traffic_data[self.current_index].values()))
        else:
            observation = np.zeros_like(list(self.traffic_data[0].values()))

        return observation, reward, done, {}

    def reset(self):
        self.current_index = 0
        self.total_reward = 0
        return np.array(list(self.traffic_data[self.current_index].values()))

# Example traffic data (simplified)
traffic_data = [
    {'ip': 203.0, 'timestamp': 1.0, 'malicious': 1},
    {'ip': 113.77, 'timestamp': 0.5, 'malicious': 0},
    {'ip': 203.0, 'timestamp': 0.9, 'malicious': 1},
    {'ip': 113.45, 'timestamp': 0.2, 'malicious': 0},
]

# Initialize the environment
env = NetworkAnalysisEnv(traffic_data)

# Train the RL agent
model = PPO("MlpPolicy", env, verbose=1)
model.learn(total_timesteps=10000)

# Test the trained model
done = False
obs = env.reset()
while not done:
    action, _ = model.predict(obs)
    obs, reward, done, _ = env.step(action)
    print(f"Action taken: {action}, Reward: {reward}")

print(f"Total Reward: {env.total_reward}")
