        print(f"Memory Allocation: {memory_allocation}")
        print(f"Process Scheduler Efficiency: {process_scheduler}")
        print(f"Resource Optimization Level: {resource_optimizer}")

        # Return OS metrics for further visualization
        return {
            "memory_allocation": memory_allocation,
            "process_scheduler": process_scheduler,
            "resource_optimizer": resource_optimizer,
        }


