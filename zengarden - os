import numpy as np
import matplotlib.pyplot as plt
import logging


class ZenGarden:
    def __init__(self, frequency=1.0):
        """
        Initialize ZenGarden for vector and spatial transformations.
        """
        self.frequency = frequency
        logging.info("ZenGarden initialized for top-level processing.")

    def generate_vector_field(self, size):
        """
        Generate a vector field for processing.
        """
        return [np.random.rand(2) for _ in range(size)]

    def apply_coherence_transform(self, vector_field):
        """
        Apply coherence transformations to a vector field.
        """
        return [vector / np.linalg.norm(vector) for vector in vector_field]

    def visualize_vector_field(self, vector_field, title="Vector Field"):
        """
        Visualize the vector field using a quiver plot with corrected grid size.
        """
        x, y = zip(*vector_field)
        grid_size = len(x)
        X, Y = np.meshgrid(range(grid_size), range(grid_size))  # Corrected grid size
        plt.quiver(X, Y, x, y, angles='xy', scale_units='xy', scale=1, color="blue")
        plt.title(title)
        plt.xlabel("X-axis")
        plt.ylabel("Y-axis")
        plt.grid(True)
        plt.show()

    def process_gate(self, size):
        """
        Simulate processing at a gate with vector transformations.
        """
        logging.info(f"Processing gate with ZenGarden, generating vector field of size {size}.")
        vector_field = self.generate_vector_field(size)
        transformed_field = self.apply_coherence_transform(vector_field)
        self.visualize_vector_field(transformed_field, title=f"Processed Vector Field at Top Gate")
        return transformed_field