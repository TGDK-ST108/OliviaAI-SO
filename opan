from sentiment_analysis import OpinionAnalyzer

class OpinionAnalysisSector:
    def __init__(self):
        self.analyzer = OpinionAnalyzer()
        self.opinion_data = []

    def collect_data(self, sources):
        """Collect data from various sources."""
        for source in sources:
            self.opinion_data.append(source.get_latest_data())
        print("Opinion data collected.")

    def analyze_opinions(self):
        """Analyze collected opinions."""
        results = self.analyzer.analyze(self.opinion_data)
        print(f"Analysis complete: {results}")
        return results