class TrifoldSpokedWheel:
    def __init__(self):
        """
        Initialize the Trifold Spoked Wheel with three components.
        """
        self.components = {
            "TGDK River": {"status": "Active", "data_flow": []},
            "TGDK Synthesizer": {"status": "Active", "iot_devices": []},
            "Komodo Explorer": {"status": "Active", "visualization": None},
        }

    def add_data_to_river(self, data):
        """
        Add data to the TGDK River component.
        """
        self.components["TGDK River"]["data_flow"].append(data)

    def add_device_to_synthesizer(self, device_name, compatibility):
        """
        Add an IoT device to the TGDK Synthesizer component.
        """
        self.components["TGDK Synthesizer"]["iot_devices"].append(
            {"device": device_name, "compatibility": compatibility}
        )

    def generate_visualization(self):
        """
        Generate a visualization in Komodo Explorer.
        """
        self.components["Komodo Explorer"]["visualization"] = "Spoked Wheel Visualization Generated"

    def display_wheel_status(self):
        """
        Display the status of the Trifold Spoked Wheel.
        """
        for component, details in self.components.items():
            print(f"{component}: {details}")


# Example Usage
trifold_wheel = TrifoldSpokedWheel()

# Add data to TGDK River
trifold_wheel.add_data_to_river("Sample Data Flow")

# Add IoT device to TGDK Synthesizer
trifold_wheel.add_device_to_synthesizer("SmartSensor 1", "Compatible")

# Generate visualization in Komodo Explorer
trifold_wheel.generate_visualization()

# Display the wheel's status
trifold_wheel.display_wheel_status()