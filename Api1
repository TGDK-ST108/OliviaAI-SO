from fastapi import FastAPI, HTTPException, Query, Body
from pydantic import BaseModel
from typing import List, Optional
import numpy as np
from quantum_sdk_toolkit import QuantumFeatureMapper, QuantumOptimizer
import hashlib
import json

app = FastAPI(
    title="Quantum Data Sharing API",
    description="An API for quantum-enhanced data sharing and collection.",
    version="1.0.0",
)

# Initialize Quantum Components
quantum_mapper = QuantumFeatureMapper(num_qubits=4)
quantum_optimizer = QuantumOptimizer()

# Define Data Models
class QuantumData(BaseModel):
    id: int
    input_values: List[float]
    metadata: Optional[dict] = {}

class SharedData(BaseModel):
    owner: str
    content: str
    hash: Optional[str] = None
    quantum_signature: Optional[str] = None


# Quantum Processing Endpoint
@app.post("/quantum/process")
async def process_quantum_data(data: QuantumData):
    try:
        # Map input values to quantum features
        mapped_features = quantum_mapper.map_features(data.input_values)
        
        # Optimize quantum features
        optimized_features = quantum_optimizer.optimize(np.array(mapped_features))
        
        # Generate a quantum signature
        quantum_signature = hashlib.sha256(
            json.dumps(optimized_features.tolist()).encode()
        ).hexdigest()

        return {
            "status": "success",
            "quantum_signature": quantum_signature,
            "optimized_features": optimized_features.tolist(),
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Quantum processing error: {str(e)}")


# Data Submission Endpoint
@app.post("/data/share")
async def share_data(data: SharedData):
    try:
        # Create a hash of the content for integrity
        content_hash = hashlib.sha256(data.content.encode()).hexdigest()
        quantum_signature = data.quantum_signature or "N/A"

        # Simulate data storage (could integrate with blockchain here)
        stored_data = {
            "owner": data.owner,
            "content": data.content,
            "hash": content_hash,
            "quantum_signature": quantum_signature,
        }

        return {
            "status": "success",
            "message": "Data shared successfully.",
            "stored_data": stored_data,
        }
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Error sharing data: {str(e)}")


# Data Collection Endpoint
@app.get("/data/collect")
async def collect_data(owner: Optional[str] = None):
    try:
        # Simulate data retrieval (mock database or storage)
        mock_database = [
            {"owner": "Alice", "content": "Example data 1", "hash": "abc123"},
            {"owner": "Bob", "content": "Example data 2", "hash": "def456"},
        ]

        # Filter by owner if provided
        filtered_data = [d for d in mock_database if d["owner"] == owner] if owner else mock_database

        return {"status": "success", "data_collected": filtered_data}
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Error collecting data: {str(e)}")


# Blockchain Integration
@app.post("/blockchain/store")
async def store_on_blockchain(data: SharedData):
    try:
        # Simulate blockchain storage with a unique transaction ID
        transaction_id = hashlib.sha256(
            (data.owner + data.content).encode()
        ).hexdigest()

        blockchain_entry = {
            "transaction_id": transaction_id,
            "owner": data.owner,
            "content": data.content,
            "hash": data.hash or hashlib.sha256(data.content.encode()).hexdigest(),
        }

        return {"status": "success", "blockchain_entry": blockchain_entry}
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Error storing on blockchain: {str(e)}")


# Quantum Validation Endpoint
@app.post("/quantum/validate")
async def validate_quantum_signature(data: SharedData):
    try:
        if not data.quantum_signature:
            raise ValueError("Quantum signature is required for validation.")

        # Example validation by rehashing the content
        recalculated_hash = hashlib.sha256(data.content.encode()).hexdigest()

        if recalculated_hash == data.hash:
            return {"status": "success", "message": "Quantum signature is valid."}
        else:
            raise ValueError("Quantum signature is invalid.")

    except Exception as e:
        raise HTTPException(status_code=400, detail=f"Validation error: {str(e)}")


