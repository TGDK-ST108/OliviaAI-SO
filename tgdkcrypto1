pragma solidity ^0.8.0;

contract TGDKPayment {
    address public owner;

    event PaymentReceived(address indexed sender, uint256 amount);
    event PaymentTransferred(address indexed recipient, uint256 amount);

    constructor() {
        owner = msg.sender;
    }

    function receivePayment() public payable {
        require(msg.value > 0, "No payment sent.");
        emit PaymentReceived(msg.sender, msg.value);
    }

    function transferFunds(address payable recipient, uint256 amount) public {
        require(msg.sender == owner, "Only owner can transfer funds.");
        require(address(this).balance >= amount, "Insufficient funds.");
        recipient.transfer(amount);
        emit PaymentTransferred(recipient, amount);
    }
}