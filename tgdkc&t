# TGDKC&T System Code Implementation

class SwordComplexor:
    """
    Handles the undervalue and complexor operations for TGDKC&T.
    """
    def __init__(self, undervalue_threshold, synthesizer):
        self.undervalue_threshold = undervalue_threshold
        self.synthesizer = synthesizer

    def process_data(self, data):
        """
        Processes data through the Sword Complexor, identifying undervalue elements.
        """
        undervalue_data = [item for item in data if item['value'] < self.undervalue_threshold]
        complexor_output = self.synthesizer.complexify(undervalue_data)
        return {
            "undervalue_data": undervalue_data,
            "complexor_output": complexor_output
        }


class TGDKSynthesizer:
    """
    Integrates synthesis operations for complexor functionality.
    """
    def __init__(self):
        self.history = []

    def complexify(self, data):
        """
        Applies synthesis to the given data.
        """
        synthesized_data = [{"id": item["id"], "synthesized_value": item["value"] * 2} for item in data]
        self.history.append(synthesized_data)
        return synthesized_data


class TGDKCTSystem:
    """
    TGDKC&T System orchestrating the Sword Complexor and TGDKSynthesizer.
    """
    def __init__(self, undervalue_threshold):
        self.synthesizer = TGDKSynthesizer()
        self.sword_complexor = SwordComplexor(undervalue_threshold, self.synthesizer)

    def run(self, input_data):
        """
        Executes the TGDKC&T process on the input data.
        """
        return self.sword_complexor.process_data(input_data)


# Example Usage
if __name__ == "__main__":
    # Initialize the TGDKC&T System with an undervalue threshold of 50
    tgdk_ct_system = TGDKCTSystem(undervalue_threshold=50)

    # Sample input data
    sample_data = [
        {"id": 1, "value": 30},
        {"id": 2, "value": 60},
        {"id": 3, "value": 45},
        {"id": 4, "value": 80}
    ]

    # Run the system
    output = tgdk_ct_system.run(sample_data)

    # Print results
    print("Undervalue Data:", output["undervalue_data"])
    print("Complexor Output:", output["complexor_output"])