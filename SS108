import hashlib
import logging
from cryptography.fernet import Fernet

# Encryption key for the creation kit
key = Fernet.generate_key()
cipher_suite = Fernet(key)

# Logging setup
logging.basicConfig(filename='creation_kit_security.log', level=logging.INFO, format='%(asctime)s - %(message)s')

# Secure file encryption
def encrypt_file(file_path):
    with open(file_path, 'rb') as file:
        encrypted_data = cipher_suite.encrypt(file.read())
    with open(file_path + '.enc', 'wb') as encrypted_file:
        encrypted_file.write(encrypted_data)
    logging.info(f"File encrypted: {file_path}")

# Access control with user roles
def check_user_access(user_role, required_role):
    if user_role != required_role:
        logging.warning(f"Access denied for user role: {user_role}")
        raise PermissionError("Access denied")
    logging.info("Access granted.")

# Hashing for integrity checks
def generate_hash(file_path):
    with open(file_path, 'rb') as file:
        file_data = file.read()
        file_hash = hashlib.sha256(file_data).hexdigest()
    logging.info(f"Hash generated for {file_path}: {file_hash}")
    return file_hash

