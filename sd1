class SpecternalDiaphragm:
    def __init__(self):
        self.capacity = 100  # Initial processing capacity
        self.rules = {"key_rule": lambda x: x % 2 == 0}  # Example rule for didactation

    def dilate(self, factor):
        """Expand the diaphragm's processing capacity."""
        self.capacity *= factor
        print(f"Dilated processing capacity to {self.capacity}")

    def didactate(self, data):
        """Apply rules to structure and process incoming data."""
        structured_data = [item for item in data if self.rules["key_rule"](item)]
        print(f"Didactated data: {structured_data}")
        return structured_data

    def kerflump(self, chaotic_data):
        """Reorganize chaotic data into a manageable structure."""
        reorganized_data = sorted(chaotic_data)
        print(f"Kerflumped data: {reorganized_data}")
        return reorganized_data

def add_rule(self, rule_name, rule_function):
        """Add a new processing rule."""
        self.rules[rule_name] = rule_function
        print(f"Added rule: {rule_name}")

def kerflump(self, chaotic_data):
        """Reorganize chaotic data based on type."""
        if isinstance(chaotic_data, list):
            reorganized_data = sorted(chaotic_data)
        elif isinstance(chaotic_data, dict):
            reorganized_data = {k: v for k, v in sorted(chaotic_data.items())}
        else:
            reorganized_data = chaotic_data  # Leave other types unchanged
        print(f"Kerflumped data: {reorganized_data}")
        return reorganized_data

# Create an instance of the Specternal Diaphragm
diaphragm = SpecternalDiaphragm()

# Step 1: Dilatation
diaphragm.dilate(1.5)  # Increase capacity by 50%

# Step 2: Didactation
data = [1, 2, 3, 4, 5, 6, 7, 8]
structured_data = diaphragm.didactate(data)

# Step 3: Kerflumping
chaotic_data = [9, 2, 7, 4, 1, 8]
reorganized_data = diaphragm.kerflump(chaotic_data)