class KomodoSearch:
    def __init__(self):
        """
        Initialize the Komodo Search system with TGDKpond and quill integration.
        """
        self.time_split_range = (1, 10)  # Example: Split durations in seconds
        self.results = []

    def query_tgdkpond(self, search_query):
        """
        Execute a query on TGDKpond using the time split mechanism.
        """
        print(f"Executing query: '{search_query}'")
        # Simulate time duration splits for dynamic search results
        for duration in range(*self.time_split_range):
            result = f"Result from duration {duration}s for query '{search_query}'"
            self.results.append(result)

    def refine_results(self, keyword):
        """
        Refine search results based on a keyword.
        """
        self.results = [result for result in self.results if keyword.lower() in result.lower()]
        print(f"Refined results with keyword '{keyword}'.")

    def display_results(self):
        """
        Display the current search results.
        """
        print("Search Results:")
        for result in self.results:
            print(f"- {result}")


class QuillTypewriter:
    def __init__(self):
        """
        Initialize the quill as an input-output mechanism for Komodo Search.
        """
        self.search_system = KomodoSearch()

    def input_query(self, query):
        """
        Take user input as a search query.
        """
        print(f"Input received: '{query}'")
        self.search_system.query_tgdkpond(query)

    def refine_query(self, keyword):
        """
        Take user input to refine the search results.
        """
        print(f"Refining results with keyword: '{keyword}'")
        self.search_system.refine_results(keyword)

    def output_results(self):
        """
        Display the final refined results.
        """
        self.search_system.display_results()


# Example Usage
komodo = QuillTypewriter()

# Input query
komodo.input_query("Komodo Search System")

# Refine query
komodo.refine_query("duration 5")

# Output results
komodo.output_results()