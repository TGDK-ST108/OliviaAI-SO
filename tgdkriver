class TGDKRiver:
    def __init__(self):
        """
        Initialize the TGDK River system with spillover gates and a corrugated matrix.
        """
        self.data_flow = []  # Main data stream
        self.spillover_data = []  # Data routed through spillover gates
        self.corrugated_matrix = []  # Desensitized data structure

    def input_data(self, data):
        """
        Add data to the main flow. If it exceeds a threshold, route through spillover gates.
        """
        threshold = 10  # Example threshold
        print(f"Input data: {data}")
        if len(self.data_flow) < threshold:
            self.data_flow.append(data)
        else:
            self.spillover_data.append(data)
            print(f"Data routed through spillover gate: {data}")

    def process_corrugated_matrix(self):
        """
        Process data from spillover gates into the corrugated matrix.
        """
        print("Processing spillover data into corrugated matrix...")
        for data in self.spillover_data:
            transformed_data = f"Processed-{data}"  # Example desensitization logic
            self.corrugated_matrix.append(transformed_data)
        self.spillover_data = []  # Clear spillover data after processing

    def display_system_state(self):
        """
        Display the current state of the TGDK River system.
        """
        print(f"Main Data Flow: {self.data_flow}")
        print(f"Corrugated Matrix: {self.corrugated_matrix}")


# Example Usage
tgdk_river = TGDKRiver()

# Input data into the TGDK River system
for i in range(15):  # Simulate 15 data inputs
    tgdk_river.input_data(f"Data-{i}")

# Process data through the corrugated matrix
tgdk_river.process_corrugated_matrix()

# Display the system state
tgdk_river.display_system_state()