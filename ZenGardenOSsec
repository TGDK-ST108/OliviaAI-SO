class ZenGardenOSWithSecurity(ZenGardenOSWithRecovery):
    def __init__(self, primary_node_metrics):
        """
        Extend ZenGarden OS to include quarantine and security operations.
        """
        super().__init__(primary_node_metrics)
        self.quarantine_log = []

    def quarantine_and_analyze(self, data):
        """
        Use Vector 1 for quarantine and analysis.
        """
        print("Running Quarantine and Analysis (Vector 1)...")
        quarantined_items = [item for item in data if len(item) > 20]  # Example condition
        self.quarantine_log.extend(quarantined_items)
        print(f"Quarantined Items: {quarantined_items}")
        return quarantined_items

    def monitor_and_validate(self, processes):
        """
        Use Vector 2 to monitor and validate processes.
        """
        print("Monitoring and Validating Processes (Vector 2)...")
        validated = [proc for proc in processes if "valid" in proc]  # Example rule
        print(f"Validated Processes: {validated}")
        return validated

    def enforce_firewall(self, actions):
        """
        Use Vector 4 as a firewall layer.
        """
        print("Enforcing Firewall Rules (Vector 4)...")
        allowed_actions = [action for action in actions if "allow" in action]  # Example rule
        print(f"Allowed Actions: {allowed_actions}")
        return allowed_actions

    def simulate_security_operations(self, data, processes, actions):
        """
        Simulate security operations using Vectors 1, 2, and 4.
        """
        quarantined_items = self.quarantine_and_analyze(data)
        validated_processes = self.monitor_and_validate(processes)
        allowed_actions = self.enforce_firewall(actions)

        # Combine results for analysis
        return {
            "quarantined_items": quarantined_items,
            "validated_processes": validated_processes,
            "allowed_actions": allowed_actions
        }


# Example data for the simulation
example_data = ["file1_safe_content", "file2_malicious_content_that_is_long"]
example_processes = ["process1_valid", "process2_invalid", "process3_valid"]
example_actions = ["allow_upload", "block_download", "allow_access"]

# Initialize the OS with security operations
zengarden_os_security = ZenGardenOSWithSecurity(primary_node_metrics)
zengarden_os_security.load_primary_node()

# Simulate quarantine and security operations
security_results = zengarden_os_security.simulate_security_operations(
    data=example_data,
    processes=example_processes,
    actions=example_actions
)

# Display security operation results
print("\nSecurity Operations Results:")
for key, value in security_results.items():
    print(f"{key.capitalize()}: {value}")