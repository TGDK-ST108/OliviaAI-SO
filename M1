import smtplib
from email.mime.text import MIMEText
from email.mime.multipart import MIMEMultipart
import logging
from flask import Flask, request, jsonify

# Flask App for Mirage OS
app = Flask(__name__)
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger("MirageOS")

# Email Configuration
SMTP_SERVER = "smtp.gmail.com"  # Example: Gmail's SMTP server
SMTP_PORT = 587
EMAIL_USERNAME = "your_email@gmail.com"  # Replace with your email
EMAIL_PASSWORD = "your_password"  # Replace with your email password

# List of law enforcement emails
LAW_ENFORCEMENT_EMAILS = [
    "example-police@lawenforcement.gov",
    "crime-reporting@agency.com",
]

# Function to send crime report
def send_crime_report(crime_details):
    try:
        # Set up email content
        subject = f"Crime Report: {crime_details.get('type', 'Unknown Crime')}"
        body = (
            f"Type of Crime: {crime_details.get('type', 'N/A')}\n"
            f"Location: {crime_details.get('location', 'Unknown')}\n"
            f"Description: {crime_details.get('description', 'No description provided')}\n"
            f"Timestamp: {crime_details.get('timestamp', 'N/A')}\n"
            f"Evidence: {crime_details.get('evidence', 'No evidence attached')}\n"
        )
        msg = MIMEMultipart()
        msg["From"] = EMAIL_USERNAME
        msg["To"] = ", ".join(LAW_ENFORCEMENT_EMAILS)
        msg["Subject"] = subject
        msg.attach(MIMEText(body, "plain"))

        # Connect to SMTP server and send email
        with smtplib.SMTP(SMTP_SERVER, SMTP_PORT) as server:
            server.starttls()
            server.login(EMAIL_USERNAME, EMAIL_PASSWORD)
            server.sendmail(EMAIL_USERNAME, LAW_ENFORCEMENT_EMAILS, msg.as_string())
        logger.info(f"Crime report sent successfully: {subject}")
    except Exception as e:
        logger.error(f"Failed to send crime report: {e}")

# API Endpoint to Receive Crime Reports
@app.route("/report_crime", methods=["POST"])
def report_crime():
    data = request.json
    logger.info(f"Received crime report: {data}")

    # Send crime report to law enforcement
    send_crime_report(data)

    return jsonify({"status": "Report sent successfully"}), 200

# Example of Triggering Crime Report
@app.route("/detect_crime", methods=["POST"])
def detect_crime():
    # Example crime detection logic
    detected_crime = {
        "type": "Fraud",
        "location": "New York, NY",
        "description": "Suspicious financial transaction detected.",
        "timestamp": "2024-12-04T12:34:56Z",
        "evidence": "Attached financial logs",
    }
    logger.info("Crime detected. Sending report.")
    send_crime_report(detected_crime)

    return jsonify({"status": "Crime detected and reported"}), 200

# Main Function to Run Mirage OS
if __name__ == "__main__":
    logger.info("Starting Mirage OS crime reporting protocol...")
    app.run(host="0.0.0.0", port=8080)
