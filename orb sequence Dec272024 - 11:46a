class OrbSequencer:
    def __init__(self):
        self.current_sequence = None
        self.security_lock = True  # Ensure TGDK-exclusive access

    def authenticate_user(self, user_id):
        # Biometric or token-based user authentication
        if user_id in authorized_users:
            self.security_lock = False
            return "Access granted."
        return "Unauthorized access."

    def process_command(self, command):
        if self.security_lock:
            return "Orb is locked. Please authenticate."
        
        if command == "Display star map":
            self.current_sequence = "Star Map"
            self.display_star_map()
        elif command == "Economic forecast":
            self.current_sequence = "Economic Forecast"
            self.display_forecast()
        else:
            return "Command not recognized."

    def display_star_map(self):
        print("Projecting star map holographically above the orb.")

    def display_forecast(self):
        print("Displaying economic forecast graphs in 3D.")

