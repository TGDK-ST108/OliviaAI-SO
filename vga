import random
import time
from datetime import datetime

class VectorGeneration:
    def __init__(self):
        self.vector_id = 0
        self.color_palette = ["Sapphire", "Emerald", "Gold", "Amethyst"]
        self.rarity_levels = ["Common", "Uncommon", "Rare", "Legendary", "Mythical"]

    def generate_vector(self):
        self.vector_id += 1
        vector = {
            "id": self.vector_id,
            "name": f"Vector {self.vector_id}: {random.choice(self.rarity_levels)} Nexus",
            "color": random.choice(self.color_palette),
            "rarity": random.choice(self.rarity_levels),
            "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "description": self.generate_description(),
        }
        return vector

    def generate_description(self):
        return (
            "A dynamically generated vector of radiant energy, pulsing with light "
            f"patterns in hues of {random.choice(self.color_palette)}. "
            "This vector embodies a unique combination of cosmic forces and technological innovation."
        )

    def continuous_generation(self, interval=60):
        while True:
            vector = self.generate_vector()
            print(vector)
          time.sleep(interval)  # Generate a new vector every X seconds
